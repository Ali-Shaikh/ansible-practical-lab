// Zero-install path for GitHub Codespaces / VS Code Dev Containers.
//
// No Dev Container Features: GHCR Feature resolve is unreliable here, and the
// python image breaks apt (Yarn GPG) during Feature install (exit 100).
// Docker + Python are installed in .devcontainer/Dockerfile from a clean
// Ubuntu 24.04 base. DinD needs privileged + a docker data volume.
{
  "name": "Ansible Practical Lab",
  "build": {
    "dockerfile": "Dockerfile",
    "context": "."
  },
  "runArgs": ["--privileged"],
  "mounts": [
    "source=dind-var-lib-docker-${devcontainerId},target=/var/lib/docker,type=volume"
  ],
  "containerEnv": {
    "DOCKER_BUILDKIT": "1"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "redhat.ansible",
        "ms-python.python"
      ]
    }
  },
  "forwardPorts": [8080],
  "portsAttributes": {
    "8080": {
      "label": "beacon web"
    }
  },
  "postCreateCommand": "pipx install --include-deps ansible && pipx install ansible-lint && ansible-galaxy collection install -r requirements.yml && for i in $(seq 1 30); do docker info >/dev/null 2>&1 && break; sleep 2; done; ./lab doctor"
}
