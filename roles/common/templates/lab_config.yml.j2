---
# Generated by Ansible common role
lab:
  environment: {{ lab_environment }}
  contact: {{ lab_contact }}
  managed_by: ansible
  features:
    - baseline
{% if 'web' in group_names %}
    - web_serving
{% endif %}
{% if 'database' in group_names %}
    - database
{% endif %}
  web_port: {{ web_listen_port | default(80) }}
  notes: "This file demonstrates Jinja2 templating and group-aware content."
