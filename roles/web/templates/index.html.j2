<!doctype html>
<html>
<head>
  <title>{{ inventory_hostname }} - {{ web_service_name | default('web') }} health</title>
  <style>
    body { font-family: system-ui, sans-serif; margin: 2rem; }
    .status { color: #0a0; font-weight: bold; }
  </style>
</head>
<body>
  <h1>✅ Served by {{ web_service_name }} on {{ inventory_hostname }}</h1>
