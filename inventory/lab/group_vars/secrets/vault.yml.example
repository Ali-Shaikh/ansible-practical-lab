---
# DEMO FILE FOR ARTICLE 7
# Copy to vault.yml in this directory, then encrypt:
#   ./lab ansible-vault encrypt inventory/lab/group_vars/secrets/vault.yml
#
# Never commit real secrets in clear text. vault.yml is gitignored.
# This file uses the .example suffix so Ansible does not auto-load it from
# group_vars (a plain .yml here would ship a plaintext password into every run).
vault_app_db_password: "correct-horse-battery-staple"
